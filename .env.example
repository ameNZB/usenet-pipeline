# ── Host paths ──────────────────────────────────────────────
# Where the agent's data + gluetun's config get bind-mounted on the
# host. docker-compose expands this as ${DATA_DIR:-./data}/agent and
# ${DATA_DIR:-./data}/gluetun so the default (./data next to the
# compose file) works without setting anything here.
# DATA_DIR=./data

# ── Site connection ──────────────────────────────────────────
SITE_URL=https://your-indexer-site.com
AGENT_TOKEN=your-agent-token-here
POLL_INTERVAL=30

# ── VPN ─────────────────────────────────────────────────────
# Provider list: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
VPN_PROVIDER=torguard
VPN_TYPE=openvpn
VPN_USER=your-vpn-username
VPN_PASS=your-vpn-password
VPN_COUNTRY=Netherlands

# Split-tunnel mode: only route torrent downloads through VPN,
# NNTP uploads go direct for full upload speed.
# Set VPN_DOWNLOAD_ONLY=true and AGENT_NETWORK_MODE=bridge to enable.
VPN_DOWNLOAD_ONLY=false
# AGENT_NETWORK_MODE=bridge        # uncomment to disable full-tunnel VPN
# VPN_PROXY_ADDR=vpn:1080          # gluetun SOCKS5 proxy (default)

# ── Usenet upload (NNTP) ────────────────────────────────────
NNTP_SERVER=news.your-provider.com:563
NNTP_SSL=true
NNTP_CONNECTIONS=10
NNTP_USER=your-usenet-username
NNTP_PASS=your-usenet-password
NNTP_GROUP=alt.binaries.test
NNTP_POSTER=agent <agent@your-domain.com>
NNTP_FROM=agent@your-domain.com
NNTP_DOMAIN=your-domain.com

# ── Branding ────────────────────────────────────────────────
# GENERATOR_NAME=usenet-pipeline    # NZB x-generator header and XML comment

# ── Processing ──────────────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=3
OBFUSCATE=false
ENCRYPT=false
PAR2_REDUNDANCY=5
# PAR2_THREADS=0                   # 0 = all cores
# PAR2_MEMORY_MB=0                 # 0 = auto
# MAX_DISK_USAGE_GB=0              # 0 = no limit
# CPU_MAX_PERCENT=85               # pause new tasks above this CPU %
# SLOW_SPEED_THRESHOLD_MBS=0.05    # reject downloads slower than this (MB/s)
# SLOW_SPEED_TIMEOUT_MINS=10       # minutes before rejection

# ── Local config UI ─────────────────────────────────────────
# Small browser UI for editing config.yml + per-tracker passkeys without
# SSH'ing in. Published to 127.0.0.1 on the host by docker-compose — reach
# it from the agent host at http://localhost:4869/.
# (4869 = APTX4869, the poison in Detective Conan.)
LOCAL_UI_PORT=4869

# ── Offline uploads ─────────────────────────────────────────
# Groups + watch folders are managed in the local UI at /groups and
# /watches. Drop a .torrent or completed file into a watched folder and
# the agent builds an NZB locally under OFFLINE_OUTPUT_DIR.
# Default path lands next to TempDir (/data/offline-output inside the
# agent container). Override if you want the NZBs written somewhere else.
# OFFLINE_OUTPUT_DIR=/data/offline-output
